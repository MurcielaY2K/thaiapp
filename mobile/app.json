{
  "expo": {
    "name": "ThaiQuest",
    "slug": "thaiquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thaiquest.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A1B"
      },
      "package": "com.thaiquest.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "ThaiQuest",
      "shortName": "ThaiQuest",
      "description": "Learn Thai through adventure — a language RPG",
      "themeColor": "#8B5CF6",
      "backgroundColor": "#0A0A1B",
      "lang": "th",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": []
  }
}
